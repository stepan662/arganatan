{
  "name": "arganatan",
  "version": "1.0.1",
  "description": "A React provider helper with stable actions for context-based state.",
  "license": "ISC",
  "author": "Stepan Granat <stepan.granat@gmail.com>",
  "repository": {
    "url": "https://github.com/stepan662/arganatan"
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "browser": "./dist/index.esm.min.js",
  "unpkg": "./dist/index.esm.min.js",
  "jsdelivr": "./dist/index.esm.min.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "browser": "./dist/index.esm.min.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c ../rollup.config.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "jsdom": "^23.0.1",
    "vitest": "^1.0.4"
  }
}
